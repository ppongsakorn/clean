generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Users & Teams ──────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String?  @map("password_hash")
  azureOid     String?  @unique @map("azure_oid")
  role         Role     @default(MEMBER)
  color        String?  // unique hex color for owner badge
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  teamId String? @map("team_id")
  team   Team?   @relation(fields: [teamId], references: [id])

  projectMembers    ProjectMember[]
  assignedTasks     TaskAssignee[]
  reportedTasks     Task[]          @relation("Reporter")
  comments          TaskComment[]
  attachments       TaskAttachment[]
  taskHistory       TaskHistory[]
  notifications     Notification[]
  failedLoginCount  Int      @default(0) @map("failed_login_count")
  lockedUntil       DateTime? @map("locked_until")
  refreshTokenHash  String?  @map("refresh_token_hash")

  @@map("users")
}

enum Role {
  ADMIN
  MEMBER
  VIEWER
}

model Team {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users    User[]
  projects Project[]

  @@map("teams")
}

// ─── Projects ───────────────────────────────────────────────────────────────

model Project {
  id          String            @id @default(cuid())
  name        String
  description String?
  color       String?
  icon        String?
  visibility  ProjectVisibility @default(TEAM)
  isArchived  Boolean           @default(false) @map("is_archived")
  showAiRatio Boolean           @default(false) @map("show_ai_ratio")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  teamId    String? @map("team_id")
  team      Team?   @relation(fields: [teamId], references: [id])
  createdBy String  @map("created_by")

  members               ProjectMember[]
  tasks                 Task[]
  milestones            Milestone[]
  customColumns         CustomColumn[]
  taskStatuses          TaskStatus[]
  notificationConfigs   NotificationConfig[]
  tags                  Tag[]

  @@map("projects")
}

enum ProjectVisibility {
  PRIVATE
  TEAM
  COMPANY
}

model ProjectMember {
  id        String      @id @default(cuid())
  role      ProjectRole @default(MEMBER)
  createdAt DateTime    @default(now()) @map("created_at")

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

enum ProjectRole {
  MANAGER
  MEMBER
  VIEWER
}

// ─── Task Statuses ───────────────────────────────────────────────────────────

model TaskStatus {
  id       String @id @default(cuid())
  name     String
  color    String
  category StatusCategory @default(ACTIVE)
  position Int    @default(0)

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  tasks Task[]

  @@map("task_statuses")
}

enum StatusCategory {
  NOT_STARTED
  ACTIVE
  DONE
}

// ─── Milestones ──────────────────────────────────────────────────────────────

model Milestone {
  id          String          @id @default(cuid())
  title       String
  description String?
  targetDate  DateTime?       @map("target_date")
  status      MilestoneStatus @default(ON_TRACK)
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  tasks Task[]

  @@map("milestones")
}

enum MilestoneStatus {
  ON_TRACK
  AT_RISK
  DELAYED
  COMPLETED
}

// ─── Tasks ───────────────────────────────────────────────────────────────────

model Task {
  id             String   @id @default(cuid())
  title          String
  description    String?  @db.Text
  priority       Priority @default(NORMAL)
  dueDate        DateTime? @map("due_date")
  estimatedHours Float?   @map("estimated_hours")
  loggedHours    Float?   @default(0) @map("logged_hours")
  progress       Int      @default(0) // 0-100
  humanPercent   Int      @default(100) @map("human_percent") // ai_percent = 100 - humanPercent
  position       Int      @default(0)
  isArchived     Boolean  @default(false) @map("is_archived")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  projectId  String  @map("project_id")
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  statusId String     @map("status_id")
  status   TaskStatus @relation(fields: [statusId], references: [id])

  milestoneId String?    @map("milestone_id")
  milestone   Milestone? @relation(fields: [milestoneId], references: [id])

  reporterId String @map("reporter_id")
  reporter   User   @relation("Reporter", fields: [reporterId], references: [id])

  parentTaskId String? @map("parent_task_id")
  parentTask   Task?   @relation("Subtasks", fields: [parentTaskId], references: [id])
  subtasks     Task[]  @relation("Subtasks")

  assignees          TaskAssignee[]
  comments           TaskComment[]
  attachments        TaskAttachment[]
  history            TaskHistory[]
  tags               TaskTag[]
  customColumnValues CustomColumnValue[]

  @@map("tasks")
}

enum Priority {
  CRITICAL
  HIGH
  NORMAL
  LOW
}

model TaskAssignee {
  taskId String @map("task_id")
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@map("task_assignees")
}

// ─── Comments & Attachments ──────────────────────────────────────────────────

model TaskComment {
  id        String   @id @default(cuid())
  body      String   @db.Text
  isEdited  Boolean  @default(false) @map("is_edited")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  taskId String @map("task_id")
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  @@map("task_comments")
}

model TaskAttachment {
  id        String   @id @default(cuid())
  fileName  String   @map("file_name")
  fileUrl   String   @map("file_url")
  fileSize  Int      @map("file_size")
  mimeType  String?  @map("mime_type")
  createdAt DateTime @default(now()) @map("created_at")

  taskId String @map("task_id")
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  @@map("task_attachments")
}

// ─── History & Audit ─────────────────────────────────────────────────────────

model TaskHistory {
  id        String   @id @default(cuid())
  field     String
  oldValue  String?  @map("old_value") @db.Text
  newValue  String?  @map("new_value") @db.Text
  changedAt DateTime @default(now()) @map("changed_at")

  taskId String @map("task_id")
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  @@map("task_history")
}

// ─── Tags ────────────────────────────────────────────────────────────────────

model Tag {
  id    String @id @default(cuid())
  name  String
  color String @default("#6B7280")

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  tasks TaskTag[]

  @@map("tags")
}

model TaskTag {
  taskId String @map("task_id")
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  tagId String @map("tag_id")
  tag   Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@map("task_tags")
}

// ─── Notifications ───────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  payload   Json
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum NotificationType {
  ASSIGNED
  MENTIONED
  STATUS_CHANGED
  MILESTONE_APPROACHING
  COMMENT_ADDED
}

model NotificationConfig {
  id               String          @id @default(cuid())
  channel          NotifyChannel
  targetType       NotifyTargetType @map("target_type")
  webhookUrl       String?         @map("webhook_url")
  lineGroupId      String?         @map("line_group_id")
  lineChannelToken String?         @map("line_channel_token")
  eventsJson       Json            @map("events_json")
  isActive         Boolean         @default(true) @map("is_active")

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("notification_configs")
}

enum NotifyChannel {
  LINE
  TEAMS
  EMAIL
}

enum NotifyTargetType {
  GROUP_CHAT
  CHANNEL
}

// ─── Custom Columns ──────────────────────────────────────────────────────────

model CustomColumn {
  id           String           @id @default(cuid())
  name         String
  type         CustomColumnType
  optionsJson  Json?            @map("options_json")
  defaultValue String?          @map("default_value")
  isRequired   Boolean          @default(false) @map("is_required")
  isPinned     Boolean          @default(false) @map("is_pinned")
  isVisible    Boolean          @default(true) @map("is_visible")
  position     Int              @default(0)

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  values CustomColumnValue[]

  @@map("custom_columns")
}

enum CustomColumnType {
  TEXT
  NUMBER
  DECIMAL
  DATE
  CHECKBOX
  DROPDOWN
  MULTI_SELECT
  URL
  EMAIL
  PHONE
  RATING
  PROGRESS
}

model CustomColumnValue {
  id        String   @id @default(cuid())
  value     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  taskId String @map("task_id")
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  columnId String       @map("column_id")
  column   CustomColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)

  @@unique([taskId, columnId])
  @@map("custom_column_values")
}
